# =============================================================================
# Secrets & credentials — never commit these
# =============================================================================
.env
.env.*
!.env.example
!**/.env.example

# API keys, certs, and auth material
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
credentials.json
secrets.json
service-account*.json
**/id_rsa
**/id_ed25519
!**/*.pub
.netrc
.npmrc

# =============================================================================
# Python (api/, worker/, scripts/)
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.dylib

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Packaging / distribution
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/
*.whl

# Test & type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Jupyter
.ipynb_checkpoints/

# =============================================================================
# Node.js / Next.js (web/)
# =============================================================================
node_modules/
.pnp
.pnp.js

# Next.js build output
.next/
out/

# Production / tooling
build/
.turbo/
.vercel/
.swc/

# TypeScript incremental build info
*.tsbuildinfo

# Env variants used by Next.js (keep .env.example tracked)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# =============================================================================
# Project storage (user uploads)
# =============================================================================
api/storage/uploads/*
!api/storage/uploads/.gitkeep

# =============================================================================
# Logs & temporary files
# =============================================================================
*.log
logs/
tmp/
temp/
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# =============================================================================
# Database dumps & local data
# =============================================================================
*.sqlite
*.sqlite3
*.db
dump/
dumps/
*.bson
*.dump

# =============================================================================
# OS-generated files
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Editors & IDEs
# =============================================================================
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.sublime-project
*.sublime-workspace
*.code-workspace

# =============================================================================
# Docker / local infra (optional local overrides)
# =============================================================================
docker-compose.override.yml
docker-compose.override.yaml

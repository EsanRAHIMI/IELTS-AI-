# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=ielts_ai_mastery

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI provider: openai | anthropic | ollama
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OCR — scanned / image-based PDF fallback (pytesseract + Pillow).
# Requires the tesseract binary: macOS  ->  brew install tesseract
OCR_ENABLED=true
OCR_DPI=200
OCR_MIN_CHARS_PER_PAGE=80
OCR_LANGUAGE=eng
# Optional cap. Leave empty to process all pages.
OCR_MAX_PAGES=

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000

# Route prefix. Empty for local dev (http://localhost:8010/auth/...).
# Production behind https://your-domain/api: API_ROOT_PREFIX=/api
API_ROOT_PREFIX=

# Amazon S3 — primary store for original/binary files.
# When these are set, originals go to S3 and Mongo keeps only the object key.
# When unset, a local dev fallback under UPLOAD_DIR is used automatically.
AWS_ACCESS_KEY_ID=AKIA******
AWS_SECRET_ACCESS_KEY=3rxkqM2******
AWS_REGION=eu-central-1
AWS_S3_BUCKET=iapp
AWS_S3_PUBLIC_BASE_URL=https://dvunuoe8609h3.cloudfront.net
S3_PRESIGN_EXPIRY=3600
